    private void txtHumanResource_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;
      if (txt == null) return;

      float startSize = 10f;     
      float minimumSize = 7f;   
      string fontName = &quot;Calibri&quot;;
      FontStyle style = FontStyle.Bold;

      float currentSize = startSize;

      txt.Font = new Font(fontName, currentSize, style);

      while (txt.CalcWidth() &gt; txt.Width &amp;&amp; currentSize &gt; minimumSize)
      {
        currentSize -= 0.5f;
        txt.Font = new Font(fontName, currentSize, style);
      }
    }


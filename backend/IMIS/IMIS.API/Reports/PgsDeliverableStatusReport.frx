  <ScriptText>using System;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
namespace FastReport
{
  public class ReportScript
  {       
   
    private bool isDirectValue; 

    private void txtDirectStatus_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;

      // Get IsDirect value and store it
      isDirectValue = Convert.ToBoolean(Report.GetColumnValue(&quot;ReportPerfomanceGovernanceSystemDto.PgsDeliverables.IsDirect&quot;));

      // Check if direct
      txt.Text = isDirectValue ? &quot;✓&quot; : &quot;&quot;;     
    }

    private void txtIndirectStatus_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;

      // Inverse of IsDirect
      txt.Text = !isDirectValue ? &quot;✓&quot; : &quot;&quot;;     
    }
    
    private void txtPGSYearStatus_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;
      object dateObj = Report.GetColumnValue(&quot;ReportPerfomanceGovernanceSystemDto.StartDate&quot;);

      DateTime dt;

      if (dateObj != null &amp;&amp; DateTime.TryParse(dateObj.ToString(), out dt))
      {
        txt.Text = &quot;PGS DELIVERABLES &quot; + dt.Year.ToString() + &quot; STATUS&quot;;
      }
      else
      {
        txt.Text = &quot;&quot;;
      }
    }


  
    

   }  
}</ScriptText>

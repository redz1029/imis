  <ScriptText>using System;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;

namespace FastReport
{
  public class ReportScript
  {

    private void KraName_BeforePrint(object sender, EventArgs e)
    {
      FastReport.TextObject textObject = sender as FastReport.TextObject;
      if (textObject == null) return;

      object value = Report.GetColumnValue(&quot;ReportKraRoadMapDto.KraName&quot;);

      textObject.Text = value + &quot; ROADMAP&quot;;
    }


    private void txtStrategicObjective_BeforePrint(object sender, EventArgs e)
    {
      FastReport.TextObject textObject = sender as FastReport.TextObject;
      if (textObject == null) return;

      object value = Report.GetColumnValue(&quot;ReportKraRoadMapDto.StrategicObjective&quot;);

      textObject.Text = value + &quot; (Strategy Objective)&quot;;     
    }
    
    
     
    
    private static bool shapePrinted = false;

    private void Data1_BeforePrint(object sender, EventArgs e)
    {
      var band = sender as FastReport.DataBand;
      if (band == null) return;

      var mainShape = Report.FindObject(&quot;MainShape&quot;) as FastReport.ShapeObject;
      var staticShape = Report.FindObject(&quot;ShapeKraDesription&quot;) as FastReport.ShapeObject;

      if (mainShape == null || staticShape == null) return;

      if (!shapePrinted)
      {
        staticShape.Visible = true;
        staticShape.Top = mainShape.Top;
        staticShape.Height = mainShape.Height;
        shapePrinted = true;
      }
      else
      {
        staticShape.Visible = false;
      }
    }
        
    private bool isEnablerValue;
   
    private void txtEnablers_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;
      if (txt == null)
        return;

      object value = Report.GetColumnValue(&quot;ReportKraRoadMapDto.Deliverables.IsEnabler&quot;);

      isEnablerValue = value != null &amp;&amp; Convert.ToBoolean(value);

      // Red Accent 2 - 80%
      Color highlightColor = Color.FromArgb(240, 220, 219);

      if (isEnablerValue)
      {
        txt.Text = &quot;✓&quot;;
        txt.FillColor = highlightColor;
        txt.TextColor = Color.Black;  
      }
      else
      {
        txt.Text = string.Empty;
        txt.FillColor = Color.Transparent;
        txt.TextColor = Color.Black;
      }
    }

    private void txtKRA_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;
      if (txt == null)
        return;

      object value = Report.GetColumnValue(&quot;ReportKraRoadMapDto.Deliverables.IsEnabler&quot;);

      bool isEnabler = value != null &amp;&amp; Convert.ToBoolean(value);

      // Red Accent 2 - 80%
      Color highlightColor = Color.FromArgb(240, 220, 219);
                                                                                                              
      if (isEnabler)
      {
        txt.FillColor = highlightColor;
        txt.TextColor = Color.Black;   
      }
      else
      {
        txt.FillColor = Color.Transparent;
        txt.TextColor = Color.Black;
      }
    }   
    
    private void txtEnabler1_BeforePrint(object sender, EventArgs e)
    {
      TextObject txt = sender as TextObject;

      if (txt != null)
      {
        txt.Fill = new SolidFill(Color.FromArgb(140, 240, 220, 219));
      }
    }
       
  }
}
</ScriptText>
